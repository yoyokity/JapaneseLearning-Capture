{
  "applicationId": "js.neutralino.zero",
  "version": "1.0.0",
  "defaultMode": "window",
  "documentRoot": "/resources/dist/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "logging": {
    "enabled": false,
    "writeToLogFile": false
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "filesystem.*",
    "window.*"
  ],
  "modes": {
    "window": {
      "webviewArgs": "--disable-web-security",
      "title": "JapaneseLearning-Capture",
      "width": 1280,
      "height": 720,
      "minWidth": 400,
      "minHeight": 200,
      "icon": "/resources/public/icon.ico",
      "center": true
    }
  },
  "cli": {
    "binaryName": "JapaneseLearning-Capture",
    "resourcesPath": "/resources/dist/",
    "extensionsPath": "/tools/",
    "frontendLibrary": {
      "patchFile": "/resources/index.html",
      "devUrl": "http://localhost:3157",
      "projectPath": "/resources/",
      "initCommand": "pnpm i",
      "devCommand": "npm run dev",
      "buildCommand": "npm run build"
    }
  }
}