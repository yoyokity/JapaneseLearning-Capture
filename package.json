{
    "name": "japanese-learning-capture",
    "type": "module",
    "version": "1.0.0",
    "description": "An Electron application with Vue and TypeScript",
    "author": "yoyokity",
    "main": "./dist/main/index.js",
    "scripts": {
        "lint": "eslint . --fix && prettier . --write --experimental-cli",
        "start": "chcp 65001 && electron-vite preview --outDir=dist",
        "dev": "chcp 65001 && electron-vite dev --outDir=dist",
        "build": "npm run build:icons && npm run build:vite",
        "build:vite": "electron-vite build --outDir=dist",
        "build:icons": "electron-icon-builder --input=./resources/icon.png --output=./build -f",
        "package": "npm run build && electron-forge package",
        "make ": "npm run build && electron-forge make"
    },
    "dependencies": {
        "sharp": "^0.34.3"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^6.2.0",
        "@better-scroll/core": "^2.5.1",
        "@better-scroll/mouse-wheel": "^2.5.1",
        "@better-scroll/scroll-bar": "^2.5.1",
        "@electron-forge/cli": "^7.8.3",
        "@electron-forge/maker-deb": "^7.8.3",
        "@electron-forge/maker-rpm": "^7.8.3",
        "@electron-forge/maker-squirrel": "^7.8.3",
        "@electron-forge/maker-zip": "^7.8.3",
        "@electron-toolkit/eslint-config-prettier": "3.0.0",
        "@electron-toolkit/eslint-config-ts": "^3.0.0",
        "@electron-toolkit/preload": "^3.0.2",
        "@electron-toolkit/tsconfig": "^1.0.1",
        "@electron-toolkit/utils": "^4.0.0",
        "@primeuix/themes": "^1.2.3",
        "@tsconfig/strictest": "^2.0.8",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^24.2.1",
        "@vitejs/plugin-vue": "^6.0.0",
        "autoprefixer": "^10.4.21",
        "cheerio": "^1.1.2",
        "chinese-simple2traditional": "^2.2.2",
        "cssnano": "^7.1.1",
        "electron": "^37.2.3",
        "electron-fetch": "^1.9.1",
        "electron-icon-builder": "^2.0.1",
        "electron-log": "^5.4.2",
        "electron-store": "^10.1.0",
        "electron-updater": "^6.3.9",
        "electron-vite": "^4.0.0",
        "es-toolkit": "^1.39.9",
        "eslint": "^9.39.0",
        "eslint-plugin-import-x": "^4.16.1",
        "fast-glob": "^3.3.3",
        "fs-extra": "^11.3.1",
        "p-queue": "^8.1.0",
        "pathe": "^2.0.3",
        "pinia": "^3.0.3",
        "pinia-plugin-persistedstate": "^4.5.0",
        "postcss": "^8.5.6",
        "prettier": "^3.6.2",
        "primeicons": "^7.0.0",
        "primevue": "^4.3.7",
        "sass": "^1.90.0",
        "terser": "^5.43.1",
        "typescript": "^5.8.3",
        "vite": "^7.0.5",
        "vite-plugin-vue-devtools": "^8.0.1",
        "vite-svg-loader": "^5.1.0",
        "vue": "^3.5.17",
        "vue-hooks-plus": "^2.4.1",
        "vue-tsc": "^3.0.3",
        "xmlbuilder2": "^3.1.1"
    }
}
