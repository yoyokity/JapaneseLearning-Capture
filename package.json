{
    "name": "japanese-learning-capture",
    "type": "module",
    "version": "2.0.0",
    "description": "日语学习资料的刮削、管理工具🤪",
    "author": "yoyokity",
    "main": "./dist/main/index.js",
    "scripts": {
        "type-check": "vue-tsc --noEmit -p tsconfig.web.json",
        "lint": "eslint . --fix && prettier . --write --experimental-cli",
        "start": "chcp 65001 && electron-vite preview --outDir=dist",
        "dev": "chcp 65001 && electron-vite dev --outDir=dist",
        "build": "npm run build:icons && npm run build:vite",
        "build:vite": "electron-vite build --outDir=dist",
        "build:icons": "electron-icon-builder --input=./resources/mainIcon.png --output=./build -f",
        "package": "npm run build && electron-forge package",
        "make ": "npm run build && electron-forge make"
    },
    "dependencies": {
        "sharp": "^0.34.3"
    },
    "devDependencies": {
        "@ai-sdk/deepseek": "^2.0.30",
        "@ai-sdk/google": "^3.0.65",
        "@ai-sdk/openai": "^3.0.54",
        "@antfu/eslint-config": "^8.2.0",
        "@electron-forge/cli": "^7.11.1",
        "@electron-forge/maker-deb": "^7.11.1",
        "@electron-forge/maker-rpm": "^7.11.1",
        "@electron-forge/maker-squirrel": "^7.11.1",
        "@electron-forge/maker-zip": "^7.11.1",
        "@electron-toolkit/tsconfig": "^2.0.0",
        "@electron-toolkit/utils": "^4.0.0",
        "@primeuix/themes": "^2.0.3",
        "@trpc/client": "10.45.2",
        "@trpc/server": "10.45.2",
        "@tsconfig/strictest": "^2.0.8",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^25.6.0",
        "@types/string-similarity": "^4.0.2",
        "@vitejs/plugin-vue": "^6.0.6",
        "ai": "^6.0.170",
        "autoprefixer": "^10.5.0",
        "cheerio": "^1.2.0",
        "chinese-simple2traditional": "^2.3.2",
        "cssnano": "^7.1.7",
        "dayjs": "^1.11.20",
        "electron": "^41.3.0",
        "electron-icon-builder": "^2.0.1",
        "electron-log": "^5.4.2",
        "electron-store": "^11.0.2",
        "electron-trpc": "^0.7.1",
        "electron-updater": "^6.8.3",
        "electron-vite": "^5.0.0",
        "es-toolkit": "^1.46.1",
        "eslint": "^10.2.1",
        "eslint-plugin-import-x": "^4.16.2",
        "fs-extra": "^11.3.4",
        "github-markdown-css": "^5.8.1",
        "iconv-lite": "^0.7.2",
        "lenis": "^1.3.23",
        "marked": "^18.0.2",
        "p-queue": "^9.2.0",
        "pathe": "^2.0.3",
        "pinia": "^3.0.3",
        "pinia-plugin-persistedstate": "^4.5.0",
        "postcss": "^8.5.12",
        "prettier": "^3.8.3",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.5",
        "sass": "^1.99.0",
        "sentence-splitter": "^5.0.1",
        "string-similarity": "^4.0.4",
        "superjson": "^2.2.6",
        "terser": "^5.46.2",
        "tinyglobby": "^0.2.16",
        "typescript": "^6.0.3",
        "uuid": "^14.0.0",
        "vite": "^8.0.10",
        "vite-plugin-vue-devtools": "^8.1.1",
        "vite-svg-loader": "^5.1.1",
        "vue": "^3.5.33",
        "vue-tsc": "^3.2.7",
        "vue-waterfall-plugin-next": "^3.0.1",
        "xmlbuilder2": "^4.0.3",
        "zod": "^4.4.1"
    }
}
