{
    "name": "japanese-learning-capture",
    "type": "module",
    "version": "1.0.0",
    "description": "An Electron application with Vue and TypeScript",
    "author": "yoyokity",
    "main": "./dist/main/index.js",
    "scripts": {
        "lint": "eslint . --fix && prettier . --write --experimental-cli",
        "start": "chcp 65001 && electron-vite preview --outDir=dist",
        "dev": "chcp 65001 && electron-vite dev --outDir=dist",
        "build": "npm run build:icons && npm run build:vite",
        "build:vite": "electron-vite build --outDir=dist",
        "build:icons": "electron-icon-builder --input=./resources/icon.png --output=./build -f",
        "package": "npm run build && electron-forge package",
        "make ": "npm run build && electron-forge make"
    },
    "dependencies": {
        "sharp": "^0.34.3"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^8.2.0",
        "@electron-forge/cli": "^7.11.1",
        "@electron-forge/maker-deb": "^7.11.1",
        "@electron-forge/maker-rpm": "^7.11.1",
        "@electron-forge/maker-squirrel": "^7.11.1",
        "@electron-forge/maker-zip": "^7.11.1",
        "@electron-toolkit/eslint-config-prettier": "3.0.0",
        "@electron-toolkit/eslint-config-ts": "^3.0.0",
        "@electron-toolkit/preload": "^3.0.2",
        "@electron-toolkit/tsconfig": "^2.0.0",
        "@electron-toolkit/utils": "^4.0.0",
        "@primeuix/themes": "^2.0.3",
        "@studio-freight/lenis": "^1.0.42",
        "@tsconfig/strictest": "^2.0.8",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^25.6.0",
        "@vitejs/plugin-vue": "^6.0.6",
        "autoprefixer": "^10.5.0",
        "cheerio": "^1.2.0",
        "chinese-simple2traditional": "^2.3.2",
        "cssnano": "^7.1.7",
        "electron": "^41.3.0",
        "electron-icon-builder": "^2.0.1",
        "electron-log": "^5.4.2",
        "electron-store": "^11.0.2",
        "electron-updater": "^6.8.3",
        "electron-vite": "^5.0.0",
        "es-toolkit": "^1.46.0",
        "eslint": "^10.2.1",
        "eslint-plugin-import-x": "^4.16.2",
        "fast-glob": "^3.3.3",
        "fs-extra": "^11.3.4",
        "iconv-lite": "^0.7.2",
        "motion-v": "^2.2.1",
        "p-queue": "^9.1.2",
        "pathe": "^2.0.3",
        "pinia": "^3.0.3",
        "pinia-plugin-persistedstate": "^4.5.0",
        "postcss": "^8.5.10",
        "prettier": "^3.8.3",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.5",
        "sass": "^1.99.0",
        "terser": "^5.46.1",
        "typescript": "^6.0.3",
        "vite": "^8.0.9",
        "vite-plugin-vue-devtools": "^8.1.1",
        "vite-svg-loader": "^5.1.1",
        "vue": "^3.5.33",
        "vue-hooks-plus": "^2.4.3",
        "vue-tsc": "^3.2.7",
        "vue-waterfall-plugin-next": "^3.0.1",
        "xmlbuilder2": "^4.0.3"
    }
}
